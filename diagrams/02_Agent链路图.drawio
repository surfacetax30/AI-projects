<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-05-26T00:00:00.000Z" agent="SOLO" version="24.0.0" type="device">
  <diagram id="agent_chain_v2" name="Agent主链路v2">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1700" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start" value="PE 发起零件 OTS 认可" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="30" width="220" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="n1" value="&lt;b&gt;节点1：认可发起&lt;/b&gt;&lt;br&gt;&lt;br&gt;① 零件号→零件类型（规则引擎匹配 + LLM兜底，新架构零件人工确认）&lt;br&gt;② 是否改款？规则+RAG召回历史案例，评估缩减范围&lt;br&gt;③ AI推荐测试项清单 + 资料清单 + 自动生成待办&lt;br&gt;④ &lt;b&gt;PE确认清单后进入下一节点&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666&quot;&gt;编排 Agent&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="110" width="980" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="n2" value="&lt;b&gt;节点2：测试资源申请&lt;/b&gt;&lt;br&gt;&lt;br&gt;① 规则引擎自动填充测试申请模板&lt;br&gt;② LLM生成申请描述（测试目的/备注/优先级）&lt;br&gt;③ 邮件API发送到测试部门&lt;br&gt;④ &lt;b&gt;PE确认后发送&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666&quot;&gt;编排 Agent（状态机 transition action）&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="300" width="980" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="n3a" value="&lt;b&gt;节点3a：邮件接收与过滤&lt;/b&gt;&lt;br&gt;&lt;br&gt;① IMAP 监听 · 新邮件 Webhook&lt;br&gt;② 规则引擎过滤：主题/发件人/附件名&lt;br&gt;③ 附件下载 → 文件类型判断&lt;br&gt;④ &lt;font style=&quot;font-size:9px;color:#666&quot;&gt;非OTS → 丢弃 | OTS → 推入队列&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666&quot;&gt;📧 邮件网关 Agent · 工程型 · IO密集型&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="465" width="470" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="n3b" value="&lt;b&gt;节点3b：报告解析与提取 ⭐核心&lt;/b&gt;&lt;br&gt;&lt;br&gt;① 多模态LLM解析 PDF/图片/Excel&lt;br&gt;② 字段提取 · 逐字段置信度评分&lt;br&gt;③ 置信度分级：≥0.90自动 | 0.75-0.89标记 | &amp;lt;0.75复核&lt;br&gt;④ 含FAIL → 触发返工分支&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666&quot;&gt;🔍 解析 Agent · AI型 · LLM密集型&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="630" y="465" width="470" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="n4" value="&lt;b&gt;节点4：资料整理&lt;/b&gt;&lt;br&gt;&lt;br&gt;① 规则引擎：按零件类型动态生成检查清单 → 逐项核对（有/无）&lt;br&gt;② LLM语义等价校验：识别版本关系 · 核对内容与零件信息一致性&lt;br&gt;③ 缺失 → 邮件提醒供应商+PE（3天超时升级）&lt;br&gt;④ 版本冲突 → 标记待PE确认&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666&quot;&gt;📋 资料 Agent · 混合型&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="635" width="980" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="n5" value="&lt;b&gt;节点5：认可会签&lt;/b&gt;&lt;br&gt;&lt;br&gt;① LLM生成认可报告摘要 + 风险提示&lt;br&gt;② RAG召回历史风险案例 → 附注参考&lt;br&gt;③ 风险项高亮 + 异常说明&lt;br&gt;④ &lt;b&gt;人工会签审批&lt;/b&gt;（AI不替代决策，只辅助）&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666&quot;&gt;📄 报告 Agent · AI型&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="815" width="980" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="n6" value="&lt;b&gt;节点6：结案归档 + 知识沉淀&lt;/b&gt;&lt;br&gt;结构化数据→PostgreSQL | 非结构化经验→RAG向量库 | 纠错记录→SFT数据集" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="990" width="820" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="end" value="认可完成 ✅" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="490" y="1080" width="120" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="rework" value="&lt;b&gt;返工分支&lt;/b&gt;&lt;br&gt;&lt;br&gt;① 严重等级判断（安全/法规→严重，其他→轻微）&lt;br&gt;② RAG召回相似FAIL案例 → LLM分析根因&lt;br&gt;③ PE确认返工范围 → 通知供应商整改&lt;br&gt;④ 整改完成 → 重新测试 → 回到节点3a&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#666&quot;&gt;报告 Agent + 编排 Agent&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="770" y="1090" width="320" height="175" as="geometry"/>
        </mxCell>
        <mxCell id="e0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="start" target="n1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="n1" target="n2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="n2" target="n3a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="附件→队列→消费" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#333333;strokeWidth=2;dashed=1;strokeColor=#F57F17;" edge="1" parent="1" source="n3a" target="n3b">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="530"/>
              <mxPoint x="630" y="530"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="n3b" target="n4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="n4" target="n5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="n5" target="n6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1" source="n6" target="end">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ef" value="发现FAIL/缺失" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;strokeWidth=2;fontColor=#b85450;" edge="1" parent="1" source="n3b" target="rework">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1100" y="595"/>
              <mxPoint x="1100" y="1090"/>
              <mxPoint x="930" y="1090"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="eret" value="返工完成 → 重新收报告" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;dashed=1;dashPattern=8 4;fontColor=#b85450;" edge="1" parent="1" source="rework" target="n3a">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="1140"/>
              <mxPoint x="300" y="1140"/>
              <mxPoint x="300" y="530"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="erej" value="会签驳回" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;dashed=1;dashPattern=8 4;fontColor=#b85450;" edge="1" parent="1" source="n5" target="n4">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="880"/>
              <mxPoint x="80" y="705"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="comm_box" value="&lt;b&gt;Agent 间通信：asyncio.Queue 事件总线 (MVP) → RabbitMQ (生产环境)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;编排Agent订阅所有事件统一决策 | 功能Agent只产出数据+事件 | 通知消费者(协程)监听事件总线发邮件/IM&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="1110" width="980" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg" value="&lt;b&gt;图例&lt;/b&gt; | 🔵 蓝色=编排调度 | 🔶 橙色=LLM密集型(解析) | 🟢 绿色=资料/规则 | 🔴 红色=报告/返工 | ⚡ 虚线=事件/异步 | ⬅ 返工回路" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#DEE2E6;fontColor=#333333;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="1350" width="980" height="55" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
