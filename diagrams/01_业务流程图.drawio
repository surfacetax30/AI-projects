        <mxCell id="title" value="&lt;b&gt;OTS 认可业务流程图 | 六节点主流程 + 返工分支 + 状态机&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2C3E50;strokeColor=#2C3E50;fontColor=#FFFFFF;fontSize=16;fontStyle=1;" vertex="1" parent="1">
