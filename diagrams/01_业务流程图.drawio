        <mxCell id="n1" value="&lt;b&gt;① 认可发起&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;PE录入零件信息&lt;br&gt;Excel批量导入&lt;br&gt;AI推荐测试类型&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4A90D9;strokeColor=#4A90D9;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="1">
